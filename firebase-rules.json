{
  "rules": {
    ".read": false,
    ".write": false,
    "users": {
      "$uid": {
        ".read":  "auth != null && auth.uid === $uid",
        ".write": "auth != null && auth.uid === $uid",
        ".indexOn": ["updatedAt", "createdAt"]
      }
    },
    "taskcommand": {
      "$anything": {
        ".read":  "auth != null",
        ".write": "auth != null"
      }
    }
  }
}
